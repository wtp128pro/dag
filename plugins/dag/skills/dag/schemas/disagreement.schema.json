{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dag/disagreement.schema.json",
  "title": "Disagreement dossier (machine-checkable extract)",
  "description": "JSON sidecar for units/<UID>/disagreement.md. Prepared for the Phase-7 Socratic gate. MUST present >=2 options; the validator additionally enforces the invariant that EXACTLY ONE option is marked recommended.",
  "type": "object",
  "additionalProperties": false,
  "required": ["subject", "question", "options"],
  "properties": {
    "subject": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "origin": { "type": "string", "enum": ["executor-verifier", "persona-persona", "criteria-conflict"] },
    "why_material": { "type": "string" },
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "recommended", "what_it_is"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "recommended": { "type": "boolean" },
          "what_it_is": { "type": "string", "minLength": 1 },
          "proposed_by": { "type": "string" },
          "evidence_for": { "type": "string" },
          "evidence_against": { "type": "string" },
          "consequences": { "type": "string" },
          "reversibility": { "type": "string" }
        }
      }
    },
    "rollback_options": { "type": "array", "items": { "type": "string" } },
    "recommendation": { "type": "string" }
  }
}
