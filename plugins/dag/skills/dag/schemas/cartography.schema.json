{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dag/cartography.schema.json",
  "title": "Cartography (machine-checkable extract)",
  "description": "JSON sidecar for CARTOGRAPHY.md. The contextual map: terrain shape, relevant elements with ground-truth authority, invariants, risks, unknowns. Prose annotations stay in CARTOGRAPHY.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["terrain_shape", "elements", "invariants"],
  "properties": {
    "run_label": { "type": "string" },
    "terrain_shape": { "type": "string", "minLength": 1 },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["element", "role", "relevance", "authority"],
        "properties": {
          "element": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "relevance": { "type": "string", "minLength": 1 },
          "authority": { "type": "string", "minLength": 1 }
        }
      }
    },
    "invariants": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "unknowns": { "type": "array", "items": { "type": "string" } }
  }
}
