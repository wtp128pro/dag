{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dag/dialogues.schema.json",
  "title": "Bounded Socratic dialogue-series transcript (machine-checkable extract)",
  "description": "Run-root dialogues.json (+ human-readable DIALOGUES.md). One record per surface INSTANCE. Own schema, RAW-parsed by the validator; ZERO required fsm-state delta (DP-21). Round counters live here, not fsm-state. Presence is version-gated at 1.10.0 (I27-T1 T1); all shape checks are T2 (fire whenever the artifact is present). anchors_baseline is the write-once GV-34 snapshot backing U04's coordinated-rewrite invariant (immutability is attestation-class — see §E).",
  "type": "object",
  "additionalProperties": false,
  "required": ["dialogues"],
  "properties": {
    "run_label": { "type": "string" },
    "dialogues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface_id", "instance", "phase", "rounds", "rounds_used", "termination"],
        "properties": {
          "surface_id": { "type": "string", "enum": ["DS-1", "DS-2", "DS-4", "DS-5", "DS-6"] },
          "instance": {
            "type": "string",
            "description": "DP-49 CLOSED per-surface vocabulary; free-form minting is a defect. Uniqueness + cardinality are validator predicates (MC-13).",
            "pattern": "^(p1|p2|p3-cartography|p2-r[0-9]+|p7-U[0-9]{2,}-[0-9]+|p8|bga-A[0-9]{2,})$"
          },
          "phase": { "type": "string", "minLength": 1 },
          "ss_refs": { "type": "array", "items": { "type": "string", "pattern": "^SS-[0-9]+$" } },
          "rounds_used": { "type": "integer", "minimum": 0, "maximum": 3 },
          "mandatory_kinds_completed": {
            "type": "array",
            "items": { "type": "string", "enum": ["R-OPEN", "R-FORBID", "R-CONFIRM", "R-GATE", "R-PROBE"] }
          },
          "rollback_ref": {
            "type": "string",
            "minLength": 1,
            "description": "DP-49: REQUIRED on a p2-r<k> re-entry instance (allOf below); the recorded rollback license (impasse-dossier choice (b) or a P7/T11 rollback-to-P2 decision)."
          },
          "rounds": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["round", "kind", "pages", "questions", "answers"],
              "properties": {
                "round": { "type": "integer", "minimum": 1, "maximum": 3 },
                "kind": { "type": "string", "enum": ["R-OPEN", "R-FORBID", "R-CONFIRM", "R-GATE", "R-PROBE"] },
                "moves_used": {
                  "type": "array", "uniqueItems": true,
                  "items": { "type": "string", "enum": ["FORK", "COUNTER", "ADMIT", "PIVOT", "RESIDUAL"] }
                },
                "pages": { "type": "integer", "minimum": 1 },
                "deferred": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "questions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["q", "move", "recommended"],
                    "properties": {
                      "qid": { "type": "string", "minLength": 1, "description": "Optional per-question id; the resolution target of answers[].q_ref and dispositions[].q_ref. U01 owns the format (interface gap — see §G handoff)." },
                      "q": { "type": "string", "minLength": 1, "pattern": "\\S" },
                      "move": { "type": "string", "enum": ["FORK", "COUNTER", "ADMIT", "PIVOT", "RESIDUAL"] },
                      "recommended": { "type": "string", "minLength": 1, "pattern": "\\S", "description": "DP-24/DP-43: REQUIRED non-blank on EVERY question." },
                      "battery_topic": { "type": "string", "enum": ["forbid", "fear", "rejection", "invariant"], "description": "R-FORBID questions only (DP-35)." },
                      "items_presented": {
                        "type": "array", "maxItems": 4,
                        "items": { "type": "string", "minLength": 1 },
                        "description": "R-CONFIRM questions only (DP-29): presented item strings VERBATIM; maxItems 4 (the stuffing-FAIL bound)."
                      }
                    }
                  }
                },
                "answers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["a", "q_ref"],
                    "properties": {
                      "a": { "type": "string", "minLength": 1, "pattern": "\\S", "description": "DP-24: the literal verbatim human answer; NEVER orchestrator-filled." },
                      "q_ref": { "type": "string", "minLength": 1 },
                      "answer_ref": { "type": "string", "description": "OPTIONAL DECISIONS.md supplement (never a substitute for a)." },
                      "deviation": { "type": "boolean", "description": "DP-24: RECOMPUTED by the validator (a vs recommended, whitespace-normalized); recorded for the sidecar." }
                    }
                  }
                },
                "dispositions": {
                  "type": "array",
                  "description": "R-CONFIRM rounds (DP-30). Per item exactly one of confirm|edit|drop.",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["item", "disposition", "origin"],
                    "properties": {
                      "item": { "type": "string", "minLength": 1, "description": "verbatim pre-round text" },
                      "disposition": { "type": "string", "enum": ["confirm", "edit", "drop"] },
                      "edited_to": { "type": "string", "minLength": 1, "description": "REQUIRED iff edit (verbatim post-round text) — allOf below." },
                      "rationale": { "type": "string", "minLength": 1, "description": "REQUIRED iff edit|drop — allOf below." },
                      "origin": { "type": "string", "enum": ["orchestrator-authored", "human-elicited"] },
                      "q_ref": { "type": "string", "minLength": 1, "description": "the R-CONFIRM question that presented it (DP-29 per-disposition join)." },
                      "elicited_round_ref": { "type": "string", "minLength": 1, "description": "human-elicited auto-confirmed items (DP-31): ref to the eliciting round instead of a presentation q_ref." },
                      "reopened_by": { "type": "string", "minLength": 1, "description": "DP-42: names new evidence when a settled item is re-presented." }
                    },
                    "allOf": [
                      { "$comment": "L8/I25: edited_to REQUIRED iff disposition==edit (forward).",
                        "if":   { "properties": { "disposition": { "const": "edit" } }, "required": ["disposition"] },
                        "then": { "required": ["edited_to"], "properties": { "edited_to": { "minLength": 1 } } } },
                      { "$comment": "L8/I25: rationale REQUIRED iff disposition in {edit,drop}.",
                        "if":   { "properties": { "disposition": { "enum": ["edit", "drop"] } }, "required": ["disposition"] },
                        "then": { "required": ["rationale"], "properties": { "rationale": { "minLength": 1 } } } },
                      { "$comment": "L8/I25: edited_to FORBIDDEN unless edit (backward — makes it a strict iff, the verify.schema disagreement-iff pattern).",
                        "if":   { "properties": { "disposition": { "enum": ["confirm", "drop"] } }, "required": ["disposition"] },
                        "then": { "not": { "required": ["edited_to"] } } }
                    ]
                  }
                },
                "probe_discharge": {
                  "type": "object", "additionalProperties": false,
                  "description": "DP-12 rung 2: probe content that entered THIS round's frozen queue.",
                  "required": ["trigger", "q_refs"],
                  "properties": {
                    "trigger": { "type": "string", "minLength": 1 },
                    "q_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
                  }
                },
                "effects": {
                  "type": "object", "additionalProperties": false,
                  "description": "DP-25 'what changed' + DP-36 forbid residue.",
                  "properties": {
                    "register_rows_resolved": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
                    "dod_edits": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                    "non_goals_added": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                    "draft_edits": {
                      "type": "array",
                      "items": {
                        "type": "object", "additionalProperties": false,
                        "required": ["item", "offered", "amendment"],
                        "properties": {
                          "item": { "type": "string", "minLength": 1, "description": "verbatim final text" },
                          "offered": { "type": "string", "minLength": 1, "description": "literal recommended echo" },
                          "amendment": { "type": "string", "minLength": 1, "description": "literal human answer span that amended it" }
                        }
                      }
                    },
                    "clean_sweep": { "type": "boolean", "description": "DP-36 (R-FORBID)." },
                    "clean_sweep_statement": { "type": "string", "minLength": 1, "description": "DP-36: REQUIRED iff clean_sweep==true — allOf below." },
                    "decisions_ref": { "type": "string", "minLength": 1 },
                    "summary": { "type": "string" }
                  },
                  "allOf": [
                    { "$comment": "L8/I25: a genuine-search statement REQUIRED iff clean_sweep true (DP-36).",
                      "if":   { "properties": { "clean_sweep": { "const": true } }, "required": ["clean_sweep"] },
                      "then": { "required": ["clean_sweep_statement"] } }
                  ]
                }
              }
            }
          },
          "termination": {
            "type": "object",
            "additionalProperties": false,
            "description": "DP-26 termination record.",
            "required": ["reason"],
            "properties": {
              "reason": { "type": "string", "enum": ["converged", "human-early", "capped-unconverged", "halt-pending"] },
              "capped_open": {
                "type": "array",
                "items": {
                  "type": "object", "additionalProperties": false,
                  "required": ["item"],
                  "properties": {
                    "item": { "type": "string", "minLength": 1 },
                    "disposition": { "type": "string", "description": "the impasse-dossier per-item choice" }
                  }
                }
              },
              "impasse_dossier": {
                "type": "object", "additionalProperties": false,
                "description": "DP-18: options in full with the ★ Recommended mark + per-item choice, or a chained halt-pending.",
                "properties": {
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object", "additionalProperties": false,
                      "required": ["option", "recommended"],
                      "properties": {
                        "option": { "type": "string", "minLength": 1 },
                        "recommended": { "type": "boolean", "description": "the ★ mark" },
                        "evidence": { "type": "string" },
                        "reversibility": { "type": "string" }
                      }
                    }
                  },
                  "per_item_choices": {
                    "type": "array",
                    "items": {
                      "type": "object", "additionalProperties": false,
                      "required": ["item", "choice"],
                      "properties": { "item": { "type": "string", "minLength": 1 }, "choice": { "type": "string", "minLength": 1 } }
                    }
                  },
                  "chained_halt_pending": { "type": "boolean" }
                }
              },
              "probes_lapsed": {
                "type": "array",
                "description": "DP-12/DP-26: one entry per fired-but-unserved obligation. cause LEGALITY is a validator predicate (MC-9/MC-10 arithmetic).",
                "items": {
                  "type": "object", "additionalProperties": false,
                  "required": ["trigger", "cause"],
                  "properties": {
                    "trigger": { "type": "string", "minLength": 1 },
                    "q_ref": { "type": "string", "minLength": 1 },
                    "item": { "type": "string", "minLength": 1 },
                    "cause": { "type": "string", "enum": ["cap-exhausted", "human-early"] }
                  }
                }
              },
              "pending_questions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "gate_answer": { "type": "string", "minLength": 1, "description": "DP-26: DS-2 REQUIRED iff reason converged|human-early (surface-level allOf); at DS-1/4/5/6 an optional echo of the R-GATE terminal answer." }
            },
            "allOf": [
              { "$comment": "L8/I25: capped_open (non-empty) + impasse_dossier REQUIRED iff capped-unconverged (DP-18).",
                "if":   { "properties": { "reason": { "const": "capped-unconverged" } }, "required": ["reason"] },
                "then": { "required": ["capped_open", "impasse_dossier"], "properties": { "capped_open": { "minItems": 1 } } } },
              { "$comment": "L8/I25: capped_open/impasse_dossier FORBIDDEN unless capped-unconverged (strict iff).",
                "if":   { "properties": { "reason": { "enum": ["converged", "human-early", "halt-pending"] } }, "required": ["reason"] },
                "then": { "allOf": [ { "not": { "required": ["capped_open"] } }, { "not": { "required": ["impasse_dossier"] } } ] } },
              { "$comment": "L8/I25: pending_questions (non-empty) REQUIRED iff halt-pending (DP-19/DP-26).",
                "if":   { "properties": { "reason": { "const": "halt-pending" } }, "required": ["reason"] },
                "then": { "required": ["pending_questions"], "properties": { "pending_questions": { "minItems": 1 } } } },
              { "$comment": "L8/I25: pending_questions FORBIDDEN unless halt-pending (strict iff).",
                "if":   { "properties": { "reason": { "enum": ["converged", "human-early", "capped-unconverged"] } }, "required": ["reason"] },
                "then": { "not": { "required": ["pending_questions"] } } }
            ]
          }
        },
        "allOf": [
          { "$comment": "DP-49: rollback_ref REQUIRED on a p2-r<k> re-entry instance.",
            "if":   { "properties": { "instance": { "pattern": "^p2-r[0-9]+$" } }, "required": ["instance"] },
            "then": { "required": ["rollback_ref"] } },
          { "$comment": "DP-26: gate_answer REQUIRED non-blank at DS-2 when reason converged|human-early (surface-level so it can read both surface_id and termination.reason).",
            "if":   { "properties": { "surface_id": { "const": "DS-2" },
                                       "termination": { "required": ["reason"], "properties": { "reason": { "enum": ["converged", "human-early"] } } } },
                      "required": ["surface_id", "termination"] },
            "then": { "properties": { "termination": { "required": ["gate_answer"] } } } }
        ]
      }
    },
    "anchors_baseline": {
      "type": "object",
      "additionalProperties": false,
      "description": "GV-34 write-once snapshot taken at P2 gate close (clarification_resolved), FIRST close only (P2 re-entry never re-snapshots). Both anchor lists VERBATIM + a content hash. Mirrors graph.json.baseline_units/fuel_initial immutability. OPTIONAL in the schema (archive-safe); fail-closed PRESENCE on an armed run is a U04 predicate (§E). See §E for the immutability argument + the honest Limitation-P scope.",
      "required": ["definition_of_done", "non_goals", "content_hash"],
      "properties": {
        "definition_of_done": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "non_goals": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "content_hash": { "type": "string", "minLength": 1, "description": "content hash over the two verbatim lists; a self-inconsistent hash is a U04 FAIL (§E)." }
      }
    }
  }
}
